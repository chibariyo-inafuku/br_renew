# Local (WP Local) site root: version only WordPress themes under app/public/wp-content/themes/
# Everything else is ignored unless negated below.

/*
!.gitignore

# Cursor project rules (share site structure / conventions with the team)
!.cursor/
.cursor/*
!.cursor/rules/
!.cursor/rules/**

!app/
/app/*
!/app/public/
/app/public/*
!/app/public/wp-content/
/app/public/wp-content/*
!/app/public/wp-content/themes/

# Optional: omit heavy / generated paths inside themes (source stays tracked)
app/public/wp-content/themes/**/node_modules/
app/public/wp-content/themes/**/vendor/
app/public/wp-content/themes/**/.sass-cache/
app/public/wp-content/themes/**/dist/cache/
